# ================================================
# FakturKu - Konfigurasi Environment
# Salin file ini ke .env dan sesuaikan nilainya
# ================================================

# App
APP_NAME=FakturKu
APP_URL=http://localhost/FakturKu/public
APP_ENV=development
APP_TIMEZONE=Asia/Jakarta

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fakturku
DB_USER=root
DB_PASS=

# Company Info
COMPANY_NAME="PT FakturKu"
COMPANY_ADDRESS="Jl. Contoh No.123, Jakarta"
COMPANY_PHONE="021-1234567"
COMPANY_EMAIL="billing@fakturku.test"

# Invoice
INVOICE_PREFIX=INV

# ================================================
# Currency & Exchange Rate
# ================================================
BASE_CURRENCY=IDR

# Exchange Rate API (pilih salah satu)
# Option 1: exchangerate.host (gratis, tanpa API key)
EXCHANGE_API_URL=https://api.exchangerate.host/latest
EXCHANGE_API_KEY=

# Option 2: Open Exchange Rates
# EXCHANGE_API_URL=https://openexchangerates.org/api/latest.json
# EXCHANGE_API_KEY=your_api_key_here

# ================================================
# Payment Gateway
# ================================================
# Provider: stripe atau midtrans
PAYMENT_PROVIDER=midtrans

# Stripe (sandbox)
STRIPE_SECRET=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Midtrans (sandbox)
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# ================================================
# Mail (SMTP)
# ================================================
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=billing@fakturku.test
MAIL_FROM_NAME=FakturKu
